# --- Slack (from https://api.slack.com/apps → your app) ---
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token-with-connections:write
SLACK_SIGNING_SECRET=your-signing-secret

# --- RAG HTTP API (same host/key as the Python stack; must reach the server from this machine) ---
RAG_BASE_URL=http://127.0.0.1:8000
RAG_API_KEY=your-api-key-with-docs-chat-index-scopes
RAG_CUSTOMER_ID=default

# Optional: only accept Slack events from this workspace (team id from Slack URL or About)
# SLACK_TEAM_ID=T01234567
