FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
# Avoid inherited CI/mirror env breaking resolution; pip 26.x has seen empty index for some packages.
ENV PIP_INDEX_URL=https://pypi.org/simple
ENV PIP_EXTRA_INDEX_URL=

WORKDIR /app

# Runtime libs needed by OCR/PDF/image stack.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    tesseract-ocr \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/requirements.txt
# Pin pip < 26: pip 26.1+ has been observed to report "No matching distribution" for PyPI
# packages (e.g. mistralai) even when wheels exist. Use a stable 25.x resolver.
RUN pip install --no-cache-dir "pip>=25.0,<26" setuptools wheel && \
    pip install --no-cache-dir -r /app/requirements.txt

COPY . /app

EXPOSE 7000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "7000"]
