FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
# Avoid inherited CI/mirror env breaking resolution; pip 26.x has seen empty index for some packages.
ENV PIP_INDEX_URL=https://pypi.org/simple
ENV PIP_EXTRA_INDEX_URL=

WORKDIR /app

# Runtime libs needed by OCR/PDF/image stack.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    tesseract-ocr \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/requirements.txt
# Pip can report "No matching distribution ... (from versions: none)" for mistralai when it
# resolves the *entire* graph together with docling + heavy ML wheels. Install everything
# except mistralai first, then mistralai alone (same constraint as requirements.txt).
# Pin pip < 26: pip 26.1+ has also been observed with odd resolver behavior on some hosts.
RUN grep -v '^mistralai' /app/requirements.txt > /app/requirements.nomistral.txt && \
    pip install --no-cache-dir "pip>=25.0,<26" setuptools wheel && \
    pip install --no-cache-dir \
      --index-url https://pypi.org/simple \
      --trusted-host pypi.org --trusted-host files.pythonhosted.org \
      -r /app/requirements.nomistral.txt && \
    pip install --no-cache-dir \
      --index-url https://pypi.org/simple \
      --trusted-host pypi.org --trusted-host files.pythonhosted.org \
      "mistralai>=1.0.0,<4" && \
    rm -f /app/requirements.nomistral.txt

COPY . /app

EXPOSE 7000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "7000"]
