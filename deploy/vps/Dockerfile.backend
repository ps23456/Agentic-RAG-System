FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1
# Avoid inherited CI/mirror env breaking resolution; pip 26.x has seen empty index for some packages.
ENV PIP_INDEX_URL=https://pypi.org/simple
ENV PIP_EXTRA_INDEX_URL=

WORKDIR /app

# Runtime libs needed by OCR/PDF/image stack.
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    git \
    tesseract-ocr \
    poppler-utils \
    libgl1 \
    libglib2.0-0 \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt /app/requirements.txt
# Pin pip < 26 for stable resolution. mistralai is installed from GitHub (see requirements.txt)
# because the PyPI "mistralai" project is quarantined and exposes no wheels on the simple API.
RUN pip install --no-cache-dir "pip>=25.0,<26" setuptools wheel && \
    pip install --no-cache-dir \
      --index-url https://pypi.org/simple \
      --trusted-host pypi.org --trusted-host files.pythonhosted.org \
      -r /app/requirements.txt

COPY . /app

EXPOSE 7000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "7000"]
