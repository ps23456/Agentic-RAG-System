# Core auth/provider keys
BACKEND_API_KEY=replace_me
GROQ_API_KEY=replace_me
OPENAI_API_KEY=
MISTRAL_OCR_API_KEY=
TENANT_SETTINGS_MASTER_KEY=replace_with_fernet_key

# CORS: use your public frontend URL (IP for now).
# Example: http://123.45.67.89
CORS_ALLOWED_ORIGINS=http://YOUR_VPS_PUBLIC_IP

# Upload limits (default off). Set true to cap at 3 files / 30 MiB per file per request.
# UPLOAD_LIMITS_ENABLED=false
# MAX_UPLOAD_FILES_PER_REQUEST=3
# MAX_UPLOAD_BYTES_PER_FILE=31457280

# Logging
LOG_LEVEL=INFO

# Persistent data paths inside the backend container.
CLAIM_SEARCH_DATA=/app/data
CHROMA_PERSIST_DIR=/app/data/chroma
TENANT_DB_PATH=/app/storage/tenant_registry.db
