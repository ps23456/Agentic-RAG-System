# Copy this file to `.env` and fill in real values. Do NOT commit `.env`.
# All keys are read at process start; restart the server after changes.

# ---- LLM providers (at least one is required) ----
# Primary LLM (preferred): Groq — fast, low cost, OpenAI-compatible API.
GROQ_API_KEY=

# Fallback LLM: OpenAI (used when Groq is missing/rate-limited).
OPENAI_API_KEY=

# Optional alternate LLMs (uncomment when used):
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# HUGGINGFACE_API_KEY=

# ---- OCR (optional but recommended for scanned PDFs/images) ----
MISTRAL_OCR_API_KEY=

# ---- Backend auth ----
# Server-side secret for protected endpoints (chat, upload, index, metrics).
# Required by `backend/security.py::require_api_key`. Generate a strong random
# value (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
BACKEND_API_KEY=

# ---- Frontend (Vite) ----
# IMPORTANT: anything prefixed with VITE_ is shipped to the browser bundle.
# Use a *separate* low-privilege client token here, NOT the BACKEND_API_KEY.
# For Stage 0 local dev only, this may equal BACKEND_API_KEY; rotate before
# deploying to any shared/public environment.
VITE_BACKEND_API_KEY=

# ---- CORS ----
# Comma-separated list of allowed browser origins. Leave empty for safe local
# defaults (localhost:3000, localhost:5173, etc.) or set explicit origins in prod.
CORS_ALLOWED_ORIGINS=

# ---- Optional overrides ----
# CLAIM_SEARCH_DATA=/absolute/path/to/data
# VECTOR_BACKEND=chroma
# CHROMA_PERSIST_DIR=/absolute/path/to/data/chroma
# LOG_LEVEL=INFO
